# ── LLM provider (plug-and-play; swap cloud Claude for a local OpenAI-compatible host) ──
# anthropic  -> native Anthropic API
# openai     -> any OpenAI-compatible endpoint (LiteLLM / Ollama / vLLM / local gateway)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=8192

# API keys (provider-specific; only the one you use is needed)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Point "openai" at a local/self-hosted endpoint, e.g. http://localhost:4000/v1
# LLM_BASE_URL=

# Persist every agent↔LLM exchange (prompt + response) for the per-run LLM I/O view at
# /ui/runs/{id}/llm. Set false to disable capture (privacy / DB size).
# PERSIST_LLM_EXCHANGES=true

# ── Per-agent model overrides (optional; blank = use the global LLM_MODEL above) ──
# AGENT_PM__MODEL=claude-opus-4-7
# AGENT_CODING__MODEL=claude-sonnet-4-6
# AGENT_REVIEWER__MODEL=claude-haiku-4-5

# ── GitHub (read-only for the source repo; required for private repos / posting comments) ──
# GITHUB_TOKEN=

# ── Postgres (LangGraph checkpointer + app tables: integrations, run registry) ──
POSTGRES_DSN=postgresql://ash:ash@localhost:5432/ash

# ── App secret (Fernet key) — encrypts integration tokens at rest. Generate:
#    python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=

# ── Admin portal (/admin) credentials ──
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# ── Local clone path for build agents (per-project override of work.local_repo_path) ──
# LOCAL_REPO_PATH=/path/to/local/clone

# ── Logging ──
LOG_LEVEL=INFO

# ── LangSmith observability (optional) ──
# Set LANGCHAIN_TRACING_V2=true to automatically trace all LangChain calls.
# Get a free API key at https://smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_...
# LANGCHAIN_PROJECT=ash
