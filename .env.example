# ── LLM provider (plug-and-play; swap cloud Claude for a local OpenAI-compatible host) ──
# anthropic  -> native Anthropic API (cloud, or a base_url override)
# openai     -> any OpenAI-compatible endpoint (LiteLLM / Ollama / vLLM / local gateway)
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-...
# Override to point at a local/self-hosted endpoint, e.g. http://localhost:4000/v1
# LLM_BASE_URL=

# Per-role models (role -> model id). Defaults shown are Anthropic ids.
PM_MODEL=claude-opus-4-7
DEV_MODEL=claude-sonnet-4-6
REVIEWER_MODEL=claude-sonnet-4-6
FIXER_MODEL=claude-sonnet-4-6

# ── GitHub (read-only for Phase 0; public repos work without a token but are rate-limited) ──
# GITHUB_TOKEN=ghp_...
